# Optional API keys for MCP servers
# The bootstrap agent will ask you for these — you can also add them later via `claude mcp add`

# GitHub MCP — enables repo operations, PR management, issue tracking
# Get one at: github.com → Settings → Developer settings → Personal access tokens
# Required scopes: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=

# Exa MCP — neural web search
# Get one at: exa.ai → Dashboard → API Keys
EXA_API_KEY=
